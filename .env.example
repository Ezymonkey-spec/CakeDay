# ============================================================
# Copy this file to ".env.local" for local testing.
# On Vercel, you'll paste these into Settings → Environment Variables.
# Lines starting with # are comments and are ignored.
# ============================================================

# Your database connection string. Neon gives you this when you
# create the database (looks like postgres://user:pass@host/db).
DATABASE_URL=

# Your Resend API key (starts with "re_").
RESEND_API_KEY=

# The "from" address on emails. Until you verify your own domain in
# Resend, you MUST use onboarding@resend.dev (and can only email yourself).
# After verifying a domain: something like "Cake Day <hello@yourdomain.com>"
EMAIL_FROM=Cake Day <onboarding@resend.dev>

# The full public address of your deployed site, no trailing slash.
# e.g. https://cakeday.vercel.app  (you'll know this after first deploy)
APP_URL=http://localhost:3000

# A long random password that protects the reminder-sending endpoint
# so only Vercel's scheduler can trigger it. Make up 30+ random characters.
CRON_SECRET=

# --- Your card business (shown in emails and on the site) ---
# The plain ones are used inside emails (server side); the
# NEXT_PUBLIC_ copies are the same values made visible to the web
# pages (Next.js only exposes variables starting with NEXT_PUBLIC_
# to the browser — a safety feature so secrets can't leak by accident).
SHOP_NAME=
SHOP_URL=
NEXT_PUBLIC_SHOP_NAME=
NEXT_PUBLIC_SHOP_URL=

# Optional: a discount code included in reminder emails.
# Set up the matching code in your shop. This is how you'll MEASURE
# whether the app actually sells cards.
DISCOUNT_CODE=

# Timezone used to decide "whose birthday is today".
REMINDER_TZ=Australia/Sydney

# How many days before a birthday the "heads up" email goes out.
# 7 = enough time to buy and post a card.
LEAD_DAYS=7
